{
  "name": "turbotunnel",
  "version": "0.1.1",
  "private": false,
  "description": "Tunnel your local dev server with a public URL, powered by Vercel WebSockets.",
  "keywords": [
    "cli",
    "localhost",
    "tunnel",
    "vercel",
    "websocket"
  ],
  "homepage": "https://github.com/eersnington/turbotunnel#readme",
  "bugs": {
    "url": "https://github.com/eersnington/turbotunnel/issues"
  },
  "license": "MIT",
  "author": "Eersnington",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eersnington/turbotunnel.git"
  },
  "bin": {
    "tt": "dist/main.js",
    "turbotunnel": "dist/main.js"
  },
  "files": [
    "dist",
    "gateway-template"
  ],
  "type": "module",
  "scripts": {
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "build": "rolldown -c",
    "prepack": "bun run --cwd ../gateway build && bun run build && bun ./scripts/prepare-package.ts"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.92",
    "effect": "4.0.0-beta.92",
    "nanoid": "^5.1.6",
    "picocolors": "^1.1.1",
    "qrcode-generator": "^2.0.4",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.92",
    "@turbotunnel/contracts": "*",
    "@turbotunnel/typescript-config": "*",
    "@types/node": "^22.15.3",
    "@types/ws": "^8.18.1",
    "rolldown": "^1.1.3",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=22"
  }
}
