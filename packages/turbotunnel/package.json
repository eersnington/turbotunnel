{
  "name": "turbotunnel",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "tt": "./dist/main.js",
    "turbotunnel": "./dist/main.js"
  },
  "files": [
    "dist",
    "gateway-template"
  ],
  "scripts": {
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "build": "rolldown -c",
    "prepack": "bun run build && bun ./scripts/prepare-package.ts"
  },
  "dependencies": {
    "@effect/platform-node": "catalog:",
    "effect": "catalog:",
    "nanoid": "catalog:",
    "picocolors": "^1.1.1",
    "ws": "catalog:"
  },
  "devDependencies": {
    "@turbotunnel/protocol": "*",
    "@turbotunnel/typescript-config": "*",
    "@types/node": "^22.15.3",
    "@types/ws": "catalog:",
    "rolldown": "^1.1.3",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
