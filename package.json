{
  "name": "turbotunnel-workspace",
  "private": true,
  "workspaces": [
    "docs",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "changeset": "changeset",
    "dev": "turbo run dev && gateway dev",
    "gateway:dev": "bun --cwd packages/gateway run dev",
    "tt": "bun packages/turbotunnel/src/main.ts",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --check",
    "format:fix": "oxfmt .",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "version-packages": "changeset version",
    "release": "turbo run build --filter turbotunnel && changeset publish",
    "check": "bun run lint && bun run format && bun run check-types && bun run test",
    "check:fix": "bun run lint:fix && bun run format:fix",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.71.0",
    "prettier": "^3.7.4",
    "turbo": "^2.10.0",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "bun@1.3.14",
  "catalog": {
    "@effect/platform-bun": "4.0.0-beta.92",
    "@effect/platform-node": "4.0.0-beta.92",
    "@effect/vitest": "4.0.0-beta.92",
    "@types/ws": "^8.18.1",
    "effect": "4.0.0-beta.92",
    "nanoid": "^5.1.6",
    "typescript": "6.0.3",
    "vitest": "4.1.9",
    "ws": "^8.18.3"
  }
}
