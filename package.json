{
  "name": "turbotunnel-workspace",
  "private": true,
  "workspaces": [
    "docs",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev && gateway dev",
    "gateway:dev": "bun --cwd packages/gateway run dev",
    "tt": "bun --cwd packages/cli src/main.ts",
    "tt:deploy": "bun --cwd packages/cli src/main.ts -- deploy",
    "tt:http": "bun --cwd packages/cli src/main.ts -- http",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --check",
    "format:fix": "oxfmt .",
    "check": "bun run lint && bun run format && bun run check-types",
    "check:fix": "bun run lint:fix && bun run format:fix",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "prettier": "^3.7.4",
    "turbo": "^2.10.0",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "bun@1.3.14",
  "catalog": {
    "@effect/platform-bun": "4.0.0-beta.92",
    "@types/ws": "^8.18.1",
    "effect": "4.0.0-beta.92",
    "nanoid": "^5.1.6",
    "typescript": "6.0.3",
    "ws": "^8.18.3"
  }
}
