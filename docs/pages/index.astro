---
import PageLayout from "blume/components/layout/PageLayout.astro";
import data from "blume:data";
import CliReference from "../components/CliReference.astro";
import FlowDiagram from "../islands/FlowDiagram.tsx";
import InstallCommand from "../islands/InstallCommand.tsx";

const { config } = data;
---

<PageLayout
  site={{ title: config.title, description: config.description }}
  logo={config.logo}
  banner={config.banner}
  analytics={config.analytics}
  navigation={data.navigation}
  favicon={config.favicon}
  appleIcon={config.appleIcon}
  fontCssVars={data.fontCssVars}
  themeMode={config.theme.mode}
  searchEnabled={config.search.enabled}
  siteUrl={config.site}
  ogEnabled={config.og.enabled}
  page={{
    title: "Turbotunnel",
    description: "Tunnel your local dev server with a public URL, powered by Vercel WebSockets.",
    route: "/",
  }}
>
  <section>
    <div
      class="mx-auto flex max-w-3xl flex-col items-center px-6 pt-24 pb-20 text-center sm:pt-32 sm:pb-24 lg:pt-40 lg:pb-28"
    >
      <h1
        class="max-w-[16ch] text-balance font-medium text-[2.4rem] leading-[1.05] tracking-tight sm:text-5xl lg:text-6xl"
      >
        Connect the Web to your Localhost
      </h1>
      <p
        class="mt-6 max-w-[48ch] text-balance text-base text-muted-foreground leading-relaxed sm:text-lg"
      >
        A tunneling service which you can deploy to your Vercel account. Built on top of Fluid
        Compute and WebSockets.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <InstallCommand client:load />
        <a
          href="/docs"
          class="inline-flex h-11 items-center gap-1.5 rounded-md px-4 font-medium text-sm transition-colors hover:bg-muted"
        >
          Quickstart
          <svg
            aria-hidden="true"
            class="size-4"
            fill="none"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <section class="border-border border-b">
    <div class="mx-auto max-w-6xl px-6 py-20 lg:py-24">
      <h2 class="text-balance font-medium text-2xl tracking-tight sm:text-3xl">How it Works</h2>
      <p class="mt-3 max-w-[72ch] text-balance text-base text-muted-foreground leading-relaxed">
        Turbotunnel connects your machine to the gateway over WebSockets, carrying requests to your
        local app and responses back. If a request lands on an instance without that connection,
        Vercel Queue sends it to one that has it.
      </p>
      <div class="mt-10">
        <FlowDiagram client:visible />
      </div>
    </div>
  </section>

  <CliReference />

  <section>
    <div
      class="mx-auto flex max-w-6xl flex-col gap-6 px-6 py-20 sm:flex-row sm:items-center sm:justify-between lg:py-24"
    >
      <p class="max-w-[36ch] text-base text-muted-foreground leading-relaxed">
        Built by <a
          href="https://x.com/eersnington"
          target="_blank"
          rel="noopener noreferrer"
          class="text-foreground"
        >eersnington</a>.
      </p>
      <div class="flex flex-wrap items-center gap-3">
        <InstallCommand client:load />
        <a
          href="/docs"
          class="inline-flex h-11 items-center gap-1.5 rounded-md border border-border bg-background px-5 font-medium text-sm transition-colors hover:bg-muted"
        >
          Read the docs
          <svg
            aria-hidden="true"
            class="size-4"
            fill="none"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</PageLayout>
