---
const commands = [
  {
    name: "tt deploy",
    args: "",
    description: "Deploy a gateway to your Vercel account and save its connection settings.",
    href: "/docs/deploy",
  },
  {
    name: "tt dev",
    args: "[--port <port>]",
    description: "Start a dev server and tunnel it in one managed process.",
    href: "/docs/dev",
  },
  {
    name: "tt http",
    args: "<port>",
    description: "Expose a running local app through the gateway.",
    href: "/docs/http",
  },
  {
    name: "tt status",
    args: "",
    description: "Inspect live tunnel processes on this machine.",
    href: "/docs/status",
  },
  {
    name: "tt list",
    args: "",
    description: "List recent tunnels reported by the configured gateway.",
    href: "/docs/list",
  },
] as const;
---

<section class="border-border border-b">
  <div class="px-6 py-16 sm:px-10 sm:py-20 lg:px-16 lg:py-24">
    <div class="grid gap-6 lg:grid-cols-[0.7fr_1.3fr] lg:items-end">
      <h2 class="text-balance font-medium text-3xl tracking-tight sm:text-4xl">
        CLI reference
      </h2>
      <div class="lg:flex lg:justify-end">
        <p class="max-w-[42ch] text-balance text-base text-muted-foreground leading-relaxed lg:text-right">
          Deploy a gateway, run tunnels, and inspect their local or gateway state.
        </p>
      </div>
    </div>

    <div class="mt-12 border-border border-t sm:mt-16">
      {
        commands.map((command) => (
          <div class="grid gap-3 border-border border-b py-6 sm:grid-cols-[16rem_minmax(0,1fr)_auto] sm:items-baseline sm:gap-8">
            <code class="font-mono text-sm">
              <span class="text-foreground">{command.name}</span>
              {command.args && <span class="text-muted-foreground"> {command.args}</span>}
            </code>
            <p class="max-w-[72ch] text-balance text-muted-foreground text-sm leading-relaxed">
              {command.description}
            </p>
            <a
              href={command.href}
              class="inline-flex items-center gap-1.5 text-muted-foreground text-sm transition-[color,transform] duration-150 hover:text-foreground active:translate-x-0.5"
            >
              {command.name} reference
              <svg
                aria-hidden="true"
                class="size-3.5"
                fill="none"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path d="M5 12h14" />
                <path d="m12 5 7 7-7 7" />
              </svg>
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>
